{
    "compilerOptions": {
        "target": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "jsx": "react-jsx",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "composite": true,
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "references": [
        {
            "path": "../core"
        }
    ],
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx"
    ]
}