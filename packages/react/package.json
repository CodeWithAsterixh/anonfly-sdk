{
  "name": "@anonfly/react",
  "version": "1.0.4",
  "type": "module",
  "description": "React UI components for Anonfly SDK",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:tsup": "tsup src/index.ts --format cjs,esm --clean --external react",
    "build:types": "tsc -p tsconfig.dts.json",
    "build": "pnpm run build:tsup && pnpm run build:types",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts --external react"
  },
  "dependencies": {
    "@anonfly/sdk": "^1.0.4",
    "lucide-react": "^0.473.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}