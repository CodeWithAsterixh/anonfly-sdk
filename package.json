{
  "name": "anonfly-sdk-monorepo",
  "private": true,
  "version": "1.0.4",
  "description": "SDK for Anonfly service",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeWithAsterixh/anonfly-sdk"
  },
  "bugs": {
    "url": "https://github.com/CodeWithAsterixh/anonfly-sdk/issues"
  },
  "homepage": "https://github.com/CodeWithAsterixh/anonfly-sdk#readme",
  "scripts": {
    "build": "turbo run build --filter=@anonfly/*",
    "test": "turbo run test --filter=@anonfly/*",
    "lint": "turbo run lint --filter=@anonfly/*",
    "format": "prettier --write \"packages/**/*.{ts,tsx}\"",
    "publish:packages": "cd packages/core && npm publish --access public && cd ../react && npm publish --access public && cd ../cli && npm publish --access public && cd ../next && npm publish --access public"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "@changesets/cli": "^2.29.8"
  },
  "packageManager": "pnpm@9.0.0"
}